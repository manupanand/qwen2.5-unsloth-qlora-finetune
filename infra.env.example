# ─────────────────────────────────────────────────────────────────────
# infra.env — Infrastructure secrets
# NEVER commit this file. Copy infra.env.example to infra.env.
# Used by: infra-docker-compose.yml
# ─────────────────────────────────────────────────────────────────────

# ── Postgres (edge-db) ────────────────────────────────────────────────
# These are used by the postgres service itself to initialise the DB,
# AND by postgres-init to connect as superuser and create lora_studio.
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=edge_dev

# Connection string for other services / local dev tools
DATABASE_URL=postgresql://dev_user:dev_password@edge-db:5432/edge_dev

# postgres-init connects using these (same as above for local dev)
PG_HOST=edge-db
PG_PORT=5432
PG_SUPERUSER=dev_user
PG_SUPERUSER_PASS=dev_password

# ── New lora_studio db + user (created by postgres-init) ──────────────
LORA_DB_NAME=lora_studio
LORA_DB_USER=lora_user
LORA_DB_PASS=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── Qdrant ────────────────────────────────────────────────────────────
QDRANT_API_KEY=change_me_qdrant_key

# ── MinIO ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET_DATASETS=lora-datasets
MINIO_BUCKET_CHECKPOINTS=lora-checkpoints
MINIO_BUCKET_ADAPTERS=lora-adapters
MINIO_BUCKET_EXPORTS=lora-exports
